# Puerto en el que correrá el servidor Backend
PORT=5000

# Entorno de ejecución (development, production)
NODE_ENV=development

# Clave secreta para firmar tokens JWT
JWT_SECRET=tu_clave_secreta_aqui

# Configuración de la Base de Datos PostgreSQL
DB_HOST=tu_host_de_base_de_datos_aqui.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_SSL=true
DB_NAME=postgres

# --- Configuración Base (Chat - Modelos de IA) ---
# URL base del proveedor de IA compatible con la API de OpenAI
AI_BASE_URL=http://tu_ip_o_dominio:8080/v1
# Clave API para el proveedor de IA
AI_API_KEY=tu_api_key_aqui
# Nombre del modelo de lenguaje (LLM) a usar
AI_MODEL=tu_modelo_de_ia.gguf

# --- Configuración Embeddings ---
# URL base para el servicio de Embeddings
EMBEDDINGS_BASE_URL=http://tu_ip_o_dominio:8080/v1
# Clave API para el servicio de Embeddings
EMBEDDINGS_API_KEY=tu_api_key_aqui
# Nombre del modelo de Embeddings a usar
EMBEDDINGS_MODEL=tu_modelo_de_embeddings.gguf
